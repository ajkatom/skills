#!/usr/bin/env python3
"""A stdlib HTTP twin for tests. Binds an ephemeral port, writes host:port to
$DF_ENDPOINT_FILE, then serves GET /greet/<name> -> 'Hello, <name>!' (200).
Behavioral mock of a 'greeter service' — never a production contract.

M12: appends a flushed ndjson observation line per request to
$DF_OBSERVER_FILE (if set): {"event":"GET","detail":<path>}. If
$DF_TWIN_VARIANT_SEED is set, the response becomes
'Hello, <name>! [vt-<sha256(seed+path).hexdigest()[:12]>]' and the
observation line gains a matching "token". Without the env vars, behavior is
unchanged from before this feature existed."""
import hashlib
import json
import os
import sys
from http.server import BaseHTTPRequestHandler, HTTPServer


class H(BaseHTTPRequestHandler):
    def do_GET(self):
        if self.path.startswith("/greet/"):
            name = self.path[len("/greet/"):]
            seed = os.environ.get("DF_TWIN_VARIANT_SEED")
            token = None
            if seed:
                digest = hashlib.sha256((seed + self.path).encode()).hexdigest()[:12]
                token = f"vt-{digest}"
                body = f"Hello, {name}! [{token}]".encode()
            else:
                body = f"Hello, {name}!".encode()
            self.send_response(200)
            self.send_header("Content-Length", str(len(body)))
            self.end_headers()
            self.wfile.write(body)
            self._observe(self.path, token)
        else:
            self.send_response(404); self.end_headers()

    def _observe(self, path, token):
        obs = os.environ.get("DF_OBSERVER_FILE")
        if not obs:
            return
        entry = {"event": "GET", "detail": path}
        if token is not None:
            entry["token"] = token
        with open(obs, "a", encoding="utf-8") as f:
            f.write(json.dumps(entry) + "\n")
            f.flush()

    def log_message(self, *a):  # quiet
        pass


def main():
    srv = HTTPServer(("127.0.0.1", 0), H)
    host, port = srv.server_address
    ep = os.environ.get("DF_ENDPOINT_FILE")
    if ep:
        with open(ep, "w", encoding="utf-8") as f:
            f.write(f"{host}:{port}")
    srv.serve_forever()


if __name__ == "__main__":
    main()
