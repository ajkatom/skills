#!/usr/bin/env python3
"""Fake builder for regression tracking tests (test_regression.py).

Inverse of fake_builder: BHV-001 (greet.py <name>) is CORRECT on the first
iteration (no feedback.json yet) but BREAKS once feedback.json exists —
modeling a builder that "fixes" one thing and regresses a previously
passing behavior. BHV-002 (usage error) is never satisfied in either state,
so the run never converges and always proceeds to a second iteration,
giving the regression (green in iter 1, red in iter 2) somewhere to show up.

Never reads scenarios directly (unreachable from the workspace) — same
information barrier as fake_builder.
"""
import json
import os
import sys

GOOD_GREET = (
    "import sys\n"
    "if len(sys.argv) < 2:\n"
    "    print(\"nope\", file=sys.stderr)\n"
    "    sys.exit(1)\n"
    "print(f\"Hello, {sys.argv[1]}!\")\n"
)
BROKEN_GREET = GOOD_GREET.replace("Hello, ", "Hi, ")


def main():
    req = json.load(sys.stdin)
    wd = req["workdir"]
    body = BROKEN_GREET if os.path.exists(os.path.join(wd, "feedback.json")) else GOOD_GREET
    with open(os.path.join(wd, "greet.py"), "w", encoding="utf-8") as f:
        f.write(body)
    print(json.dumps({"adapter_protocol": "0.1", "status": "ok", "detail": "",
                      "usage": {"known": False}}))


if __name__ == "__main__":
    main()
