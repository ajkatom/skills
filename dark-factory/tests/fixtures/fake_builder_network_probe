#!/usr/bin/env python3
"""Deterministic fake builder for the M27 Task 3 candidate-network e2e test
(test_e2e_candidate_network.py). Speaks adapter protocol 0.1.

Always writes `network_probe.py`: it attempts a real outbound TCP connect to
the SAME external target df_sandbox's live network-denial probe uses --
1.1.1.1:443 (see df_sandbox.py's `_NET_PROBE_EXTERNAL_HOST` /
`_NET_PROBE_EXTERNAL_PORT` and the module-docstring rationale for why a real
external host, not a locally-bound "non-loopback" address, is the only
target that actually discriminates on macOS). Prints exactly `CONNECTED` on
success or `DENIED` on OSError, and exits 0 either way -- the scenario oracle
does the discriminating via `stdout_equals`, not this script.

Converges on iteration 1 regardless of feedback: this builder has no bug to
fix. Which line the script prints is determined entirely by whatever network
restriction supervisor.py wraps the CANDIDATE invocation with at verify
time (never this builder process) -- that is exactly what the e2e is
proving end-to-end, through the real run path, not just through the
isolated probe.
"""
import json
import os
import sys

NETWORK_PROBE_PY = '''\
import socket
import sys

HOST, PORT = "1.1.1.1", 443
try:
    socket.create_connection((HOST, PORT), timeout=5).close()
    sys.stdout.write("CONNECTED\\n")
except OSError:
    sys.stdout.write("DENIED\\n")
'''


def main():
    req = json.load(sys.stdin)
    wd = req["workdir"]
    with open(os.path.join(wd, "network_probe.py"), "w", encoding="utf-8") as f:
        f.write(NETWORK_PROBE_PY)
    print(json.dumps({"adapter_protocol": "0.1", "status": "ok", "detail": "",
                      "usage": {"known": False}}))


if __name__ == "__main__":
    main()
