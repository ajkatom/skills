#!/usr/bin/env python3
"""Deterministic fake AUTHOR adapter (M42) that models an author REVISING its
scenario set in response to a critic's blocking finding. First invocation (no
critic marker in the prompt): emits a valid, sharp, happy-only base set for the
greet spec. Once the prompt carries the critic-feedback marker ('critic flagged
BLOCKING'), it emits a REVISED set that ADDS a scenario titled 'revised extra'
(the token fake_critic_gap looks for to clear its blocking finding). Proves the
author<->critic loop consumes barrier-safe blocking feedback and converges.

All scenarios are sharp (assert scenario-specific exact values) and non-leaking
(the greet SPEC in the test never contains these literal outputs)."""
import json
import os
import sys

BASE = [
    {"behavior_id": "BHV-001", "cohort": "dev", "class": "happy",
     "run": ["python3", "greet.py", "World"],
     "then": {"exit_code": 0, "stdout_equals": "Hello, World!"},
     "title": "greets World"},
    {"behavior_id": "BHV-002", "cohort": "dev", "class": "happy",
     "run": ["python3", "greet.py"],
     "then": {"exit_code": 2, "stderr_contains": "greet.py <name>"},
     "title": "missing arg errors"},
]
EXTRA = {"behavior_id": "BHV-001", "cohort": "dev", "class": "happy",
         "run": ["python3", "greet.py", "Alon"],
         "then": {"exit_code": 0, "stdout_equals": "Hello, Alon!"},
         "title": "revised extra"}


def main():
    req = json.load(sys.stdin)
    wd = req["workdir"]
    prompt = ""
    try:
        with open(req["prompt_file"], encoding="utf-8") as f:
            prompt = f.read()
    except OSError:
        pass
    scenarios = list(BASE)
    if "critic flagged BLOCKING" in prompt:
        scenarios = list(BASE) + [EXTRA]
    with open(os.path.join(wd, "scenarios.json"), "w", encoding="utf-8") as f:
        json.dump({"scenarios": scenarios}, f)
    print(json.dumps({"adapter_protocol": "0.1", "status": "ok", "detail": "",
                      "usage": {"known": False}}))


if __name__ == "__main__":
    main()
