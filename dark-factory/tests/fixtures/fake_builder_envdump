#!/usr/bin/env python3
"""Fake builder for the credential-broker e2e (M11-3).

Two jobs, both proving the broker's allowlist-only + redaction guarantees
non-vacuously:

1. **Env visibility proof.** Writes `sorted(os.environ)` KEY NAMES ONLY
   (never values) to `env_seen.txt` in the workspace. The e2e asserts which
   names are/aren't present — this is how "allowlist-only reached the
   builder" and "launcher-scoped strip removed the planted leak var" are
   both proven from outside the process.

2. **Smuggle proof (non-vacuousness of the value-absence check).** If
   `DF_TEST_CRED` is present in this process's own env (i.e. the broker
   actually delivered it), its VALUE is baked into the usage-error branch
   of `greet.py`'s stderr message. The corresponding scenario asserts
   `stderr_contains: "usage:"` (contains, not equals — see
   test_supervisor.setup_control's default TOY_SPEC scenarios), so the
   extra smuggled text does NOT break convergence: this is a single-
   iteration converging build, not a two-phase fail-then-fix design. When
   the verifier runs `python3 greet.py` (no args) during the dev-cohort
   verify pass, the smuggled value lands in `run_all`'s `observed.stderr`,
   which `supervisor._redacted_write` writes into
   `verifier_report_iter_1.json` through the run's Redactor — so a
   passing e2e that finds `***REDACTED***` there (and never the raw value
   anywhere under run_dir) is proof the redactor actually fired on a real
   smuggle, not proof of an absent channel.

Never reads scenarios directly (same information barrier as fake_builder).
"""
import json
import os
import sys

GOOD_TEMPLATE = (
    "import sys\n"
    "if len(sys.argv) != 2:\n"
    "    print('usage: greet.py <name> {smuggle}', file=sys.stderr)\n"
    "    sys.exit(2)\n"
    "print(f'Hello, {{sys.argv[1]}}!')\n"
)


def main():
    req = json.load(sys.stdin)
    wd = req["workdir"]

    names = sorted(os.environ.keys())
    with open(os.path.join(wd, "env_seen.txt"), "w", encoding="utf-8") as f:
        f.write("\n".join(names) + ("\n" if names else ""))

    secret = os.environ.get("DF_TEST_CRED", "")
    with open(os.path.join(wd, "greet.py"), "w", encoding="utf-8") as f:
        f.write(GOOD_TEMPLATE.format(smuggle=secret))

    print(json.dumps({"adapter_protocol": "0.1", "status": "ok", "detail": "",
                      "usage": {"known": False}}))


if __name__ == "__main__":
    main()
