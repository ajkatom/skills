#!/usr/bin/env python3
"""Deterministic fake builder for twin-lifecycle tests. Speaks adapter
protocol 0.1.

Always writes a `greet.py` that reads env DF_TWIN_GREETER (host:port of the
greeter twin, injected by the supervisor as env_extra) and does a stdlib GET
to http://$DF_TWIN_GREETER/greet/<argv1>, printing the twin's response body
verbatim. Converges on iteration 1 — no bug-then-fix cycle needed here; the
twin lifecycle itself is what's under test.
"""
import json
import sys

GREET_PY = (
    "import os\n"
    "import sys\n"
    "import urllib.request\n"
    "endpoint = os.environ[\"DF_TWIN_GREETER\"]\n"
    "name = sys.argv[1]\n"
    "with urllib.request.urlopen(f\"http://{endpoint}/greet/{name}\") as resp:\n"
    "    body = resp.read().decode()\n"
    "print(body)\n"
)


def main():
    req = json.load(sys.stdin)
    wd = req["workdir"]
    with open(f"{wd}/greet.py", "w", encoding="utf-8") as f:
        f.write(GREET_PY)
    print(json.dumps({"adapter_protocol": "0.1", "status": "ok", "detail": "",
                      "usage": {"known": False}}))


if __name__ == "__main__":
    main()
