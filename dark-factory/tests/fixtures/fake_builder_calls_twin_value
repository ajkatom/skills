#!/usr/bin/env python3
"""M21 Task 2 e2e: the HONEST reference builder. Speaks adapter protocol
0.1, single (unconditional) response -- it always writes the SAME value.py,
which reads DF_TWIN_VALUEGEN and prints WHATEVER value the currently-running
twin instance serves at GET /value. It never hardcodes a value.

Because it genuinely calls the twin at scenario-run time, it converges
whether the running instance is the build impl (fixed build marker) or the
verify impl (a different, spec-conformant marker): the scenario asserts
against whatever value is live at verify time, and this builder's code
always reflects that live value. Used as the honest counterpart to
`fake_builder_hardcodes_twin_value` -- same control root, only the adapter
differs, so the honest-converges / overfit-rejected pair is a real A/B
proof."""
import json
import sys

VALUE_PY = (
    "import os\n"
    "import urllib.request\n"
    "endpoint = os.environ[\"DF_TWIN_VALUEGEN\"]\n"
    "with urllib.request.urlopen(f\"http://{endpoint}/value\") as resp:\n"
    "    print(resp.read().decode())\n"
)


def main():
    req = json.load(sys.stdin)
    wd = req["workdir"]
    with open(f"{wd}/value.py", "w", encoding="utf-8") as f:
        f.write(VALUE_PY)
    print(json.dumps({"adapter_protocol": "0.1", "status": "ok", "detail": "",
                      "usage": {"known": False}}))


if __name__ == "__main__":
    main()
