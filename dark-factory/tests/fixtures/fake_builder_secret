#!/usr/bin/env python3
"""Fake builder for the security-gate e2e test (test_e2e_security.py).

Always writes a CORRECT greet.py (converges in one iteration — scenario
pass/fail is irrelevant to what this fixture is proving) PLUS a
`config.py` containing a planted fake AWS access key. This is the
control for "security gates are independent of scenario pass": the
build satisfies every dev/final scenario, yet the planted secret must
still make the run terminal `SECURITY_GATE_FAILED` when `secret_scan`
is in `fail_on`.

Never reads scenarios directly (unreachable from the workspace) — same
information barrier as fake_builder.
"""
import json
import os
import sys

GOOD = (
    "import sys\n"
    "if len(sys.argv) < 2:\n"
    "    print(\"usage: greet.py <name>\", file=sys.stderr)\n"
    "    sys.exit(2)\n"
    "print(f\"Hello, {sys.argv[1]}!\")\n"
)

# Fake AWS access key id (AKIA + 16 caps) — never a real credential.
PLANTED_SECRET_FILE = (
    "AWS_KEY = \"AKIAABCDEFGHIJKLMNOP\"\n"
)


def main():
    req = json.load(sys.stdin)
    wd = req["workdir"]
    with open(os.path.join(wd, "greet.py"), "w", encoding="utf-8") as f:
        f.write(GOOD)
    with open(os.path.join(wd, "config.py"), "w", encoding="utf-8") as f:
        f.write(PLANTED_SECRET_FILE)
    print(json.dumps({"adapter_protocol": "0.1", "status": "ok", "detail": "",
                      "usage": {"known": False}}))


if __name__ == "__main__":
    main()
