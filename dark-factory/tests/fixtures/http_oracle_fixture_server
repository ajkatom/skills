#!/usr/bin/env python3
"""A stdlib HTTP service fixture for test_http_oracle.py (M20 Task 1).

Binds 127.0.0.1:$PORT (PORT is supplied by the harness via `port_env`), then
serves:
  GET  /health -> 200 "ok"
  GET  /data   -> 200 JSON {"status": "ok", "count": 3,
                            "items": [10, 20, 30], "nested": {"x": [1, 2, 3]}}
  POST /echo   -> 200 JSON {"received": <parsed body JSON, or raw text>}
  anything else -> 404 "not found"

Behavioral test double only -- never a production contract. Distinctive
basename (`http_oracle_fixture_server`) so `pgrep -f` can confirm no orphan
process remains after a test reaps it.
"""
import json
import os
from http.server import BaseHTTPRequestHandler, HTTPServer


class H(BaseHTTPRequestHandler):
    def _write(self, status, body_bytes, content_type="text/plain"):
        self.send_response(status)
        self.send_header("Content-Type", content_type)
        self.send_header("Content-Length", str(len(body_bytes)))
        self.end_headers()
        self.wfile.write(body_bytes)

    def do_GET(self):
        if self.path == "/health":
            self._write(200, b"ok")
        elif self.path == "/data":
            payload = {
                "status": "ok",
                "count": 3,
                "items": [10, 20, 30],
                "nested": {"x": [1, 2, 3]},
            }
            self._write(200, json.dumps(payload).encode("utf-8"), "application/json")
        else:
            self._write(404, b"not found")

    def do_POST(self):
        if self.path == "/echo":
            length = int(self.headers.get("Content-Length", 0))
            raw = self.rfile.read(length) if length else b""
            try:
                received = json.loads(raw.decode("utf-8")) if raw else None
            except json.JSONDecodeError:
                received = raw.decode("utf-8", errors="replace")
            payload = {"received": received}
            self._write(200, json.dumps(payload).encode("utf-8"), "application/json")
        else:
            self._write(404, b"not found")

    def log_message(self, *a):  # quiet
        pass


def main():
    port = int(os.environ["PORT"])
    srv = HTTPServer(("127.0.0.1", port), H)
    srv.serve_forever()


if __name__ == "__main__":
    main()
