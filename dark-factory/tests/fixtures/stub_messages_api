#!/usr/bin/env python3
"""A stdlib stub Anthropic Messages-API endpoint for test_api_adapter.py
(M24 Task 1). Binds an ephemeral 127.0.0.1 port, writes host:port to
$DF_ENDPOINT_FILE (same convention as tests/fixtures/twin_marker_server so a
test can wait for readiness the same way), then serves:

  POST /v1/messages -> a canned Messages-shaped response
      {"content": [{"type": "text", "text": <string>}]}
      where <string> is shaped per $DF_STUB_MODE:
        greet    -> {"files": {"greet.py": <a small greet script>}}
        badshape -> plain prose, not JSON at all -- exercises the adapter's
                    "unparseable model reply" path (covers both "wrong
                    shape" and "non-JSON": prose is both).
        unsafe   -> {"files": {"../../escaped": "pwned",
                                "/etc/escaped": "pwned"}} -- two different
                    escape techniques in the SAME reply, so a test can prove
                    all-or-nothing validation (neither gets written).
        http500  -> ignored; the handler responds HTTP 500 instead of 200.
        (anything else, including unset) -> greet.

  GET  /_requests -> {"count": <number of POST /v1/messages this process has
      served since it started>}. Lets a test assert a call was (or, for the
      missing-API-key case, was NOT) made, without needing any instrumentation
      inside the adapter under test.

  anything else -> 404.

Behavioral test double only, never a production contract. No paid calls, no
network beyond 127.0.0.1. Distinctive basename (`stub_messages_api`) so
`pgrep -f` can confirm no orphan process remains after a test reaps it.
"""
import json
import os
import threading
from http.server import BaseHTTPRequestHandler, HTTPServer

_GREET_PY = '''import sys
name = sys.argv[1] if len(sys.argv) > 1 else "World"
print(f"Hello, {name}!")
'''

_LOCK = threading.Lock()
_COUNT = 0


class H(BaseHTTPRequestHandler):
    def _write_json(self, status, obj):
        body = json.dumps(obj).encode("utf-8")
        self.send_response(status)
        self.send_header("Content-Type", "application/json")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)

    def do_GET(self):
        if self.path == "/_requests":
            with _LOCK:
                count = _COUNT
            self._write_json(200, {"count": count})
        else:
            self._write_json(404, {"error": "not found"})

    def do_POST(self):
        global _COUNT
        if self.path != "/v1/messages":
            self._write_json(404, {"error": "not found"})
            return
        length = int(self.headers.get("Content-Length", 0) or 0)
        if length:
            self.rfile.read(length)  # drain the request body; unused by the stub
        with _LOCK:
            _COUNT += 1

        mode = os.environ.get("DF_STUB_MODE", "greet")
        if mode == "http500":
            self._write_json(500, {"error": "internal stub error"})
            return
        if mode == "unsafe":
            text = json.dumps({"files": {
                "../../escaped": "pwned",
                "/etc/escaped": "pwned",
            }})
        elif mode == "badshape":
            text = "Sure, here is my answer: I decline to produce JSON."
        else:  # "greet" and any unrecognized mode
            text = json.dumps({"files": {"greet.py": _GREET_PY}})
        if mode == "thinking":
            # Extended-thinking models (e.g. claude-sonnet-5) emit a thinking
            # block BEFORE the text block, so content[0] is NOT the answer.
            # The adapter must skip it and take the first text block. (This is
            # the exact shape a live claude-sonnet-5 KV build returned.)
            self._write_json(200, {"content": [
                {"type": "thinking", "thinking": "Let me plan the greet script..."},
                {"type": "text", "text": text},
            ]})
            return
        self._write_json(200, {"content": [{"type": "text", "text": text}]})

    def log_message(self, *a):  # quiet
        pass


def main():
    srv = HTTPServer(("127.0.0.1", 0), H)
    host, port = srv.server_address
    ep = os.environ.get("DF_ENDPOINT_FILE")
    if ep:
        with open(ep, "w", encoding="utf-8") as f:
            f.write(f"{host}:{port}")
    srv.serve_forever()


if __name__ == "__main__":
    main()
