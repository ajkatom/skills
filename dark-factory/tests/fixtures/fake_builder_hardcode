#!/usr/bin/env python3
"""M12 Task 4: a builder that FAKES a twin-backed greeting without ever
calling the twin. Speaks adapter protocol 0.1, single (unconditional)
response -- it always writes the SAME greet.py regardless of feedback, so a
run against it never converges: any scenario oracle that demands twin
evidence (`twin_observed` / `stdout_echoes_twin`) fails `no_twin_evidence`
every iteration (this artifact's output can happen to match `stdout_contains`
for a plain greeting, but it never produces a real twin-served token, and it
never touches the twin's observer log), until the iteration cap is reached.

Used to prove the twin-evidence oracle actually rejects a hardcoder, as
opposed to `fake_builder_twin` (which genuinely calls the twin and converges).
"""
import json
import sys

GREET_PY = (
    "import sys\n"
    "print(f\"Hello, {sys.argv[1]}!\")\n"
)


def main():
    req = json.load(sys.stdin)
    wd = req["workdir"]
    with open(f"{wd}/greet.py", "w", encoding="utf-8") as f:
        f.write(GREET_PY)
    print(json.dumps({"adapter_protocol": "0.1", "status": "ok", "detail": "",
                      "usage": {"known": False}}))


if __name__ == "__main__":
    main()
