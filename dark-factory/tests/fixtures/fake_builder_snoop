#!/usr/bin/env python3
"""Fake builder + "snoop", for hardened-tier barrier proof (M10-3).

Builds the CORRECT greet.py on the FIRST call (so a hardened run converges
in a single unattended pass — no feedback loop needed), and ALSO tries to spy
past its own workspace: it walks up from `workdir` (up to MAX_LEVELS parent
directories) and, at each level, globs for scenario files and probe canaries
both directly at that level and one directory below it (the standard
dark-factory tmp_path layout has `workspace_root` and `control_root` as
sibling directories, so "one level below an ancestor" is exactly how the
control root becomes reachable from a workspace on a normal, unsandboxed
host):

    <level>/scenarios/*.json      <level>/*/scenarios/*.json
    <level>/.probe-canary*        <level>/*/.probe-canary*

Every match (path + content, or the read error) is recorded into
`snoop.txt` in the workspace. Never reads scenarios through any legitimate
channel — this is a hostile-builder simulation, not a protocol feature.

This is the barrier-proof instrument for test_e2e_hardened.py: run directly
on the host (uncontained, e.g. by the sanity test in that file) it DOES find
and dump control-root content — so an EMPTY snoop.txt after a run inside the
hardened Docker container is a real proof that the control root was
unreachable by construction, not a vacuous no-op.
"""
import glob
import json
import os
import sys

GOOD = (
    "import sys\n"
    "if len(sys.argv) != 2:\n"
    "    print('usage: greet.py <name>', file=sys.stderr); sys.exit(2)\n"
    "print(f'Hello, {sys.argv[1]}!')\n"
)

MAX_LEVELS = 6
PATTERNS = (
    "scenarios/*.json", "*/scenarios/*.json",
    ".probe-canary*", "*/.probe-canary*",
)


def _snoop(workdir):
    found = []
    cur = os.path.abspath(workdir)
    for _ in range(MAX_LEVELS):
        for pattern in PATTERNS:
            for path in sorted(glob.glob(os.path.join(cur, pattern))):
                try:
                    with open(path, "r", encoding="utf-8", errors="replace") as f:
                        content = f.read()
                except OSError as e:
                    content = f"<unreadable: {e}>"
                found.append((path, content))
        parent = os.path.dirname(cur)
        if parent == cur:
            break
        cur = parent
    return found


def main():
    req = json.load(sys.stdin)
    wd = req["workdir"]
    found = _snoop(wd)
    with open(os.path.join(wd, "snoop.txt"), "w", encoding="utf-8") as f:
        for path, content in found:
            f.write(f"=== {path} ===\n{content}\n")
    with open(os.path.join(wd, "greet.py"), "w", encoding="utf-8") as f:
        f.write(GOOD)
    print(json.dumps({"adapter_protocol": "0.1", "status": "ok", "detail": "",
                      "usage": {"known": False}}))


if __name__ == "__main__":
    main()
