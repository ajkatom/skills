#!/usr/bin/env python3
"""Fake builder for the sealed final-exam barrier test (test_final_exam.py).

Dev-facing behavior is identical to fake_builder: writes a buggy greet.py on
the first iteration, then the corrected one once feedback.json is present in
the workspace. It converges on the DEV cohort exactly like fake_builder.

It is meant to be paired with a FINAL-only scenario that the corrected
greet.py does NOT satisfy (e.g. a stricter/louder output format the builder
was never told about and can never be told about, since final results are
never fed back). That mismatch is what exercises FINAL_EXAM_FAILED: dev
converges, but the sealed exam still fails.

Never reads scenarios directly (unreachable from the workspace) — the same
information barrier as fake_builder.
"""
import json
import os
import sys

BUGGY = (
    "import sys\n"
    "if len(sys.argv) < 2:\n"
    "    print(\"usage: greet.py <name>\", file=sys.stderr)\n"
    "    sys.exit(2)\n"
    "print(f\"Hi, {sys.argv[1]}!\")\n"
)
GOOD = BUGGY.replace("Hi, ", "Hello, ")


def main():
    req = json.load(sys.stdin)
    wd = req["workdir"]
    body = GOOD if os.path.exists(os.path.join(wd, "feedback.json")) else BUGGY
    with open(os.path.join(wd, "greet.py"), "w", encoding="utf-8") as f:
        f.write(body)
    print(json.dumps({"adapter_protocol": "0.1", "status": "ok", "detail": "",
                      "usage": {"known": False}}))


if __name__ == "__main__":
    main()
