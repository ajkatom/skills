#!/usr/bin/env python3
"""DF-R4-02 (M52) impostor: an executable that merely SHARES the basename
`api_anthropic` with this skill's shipped structural adapter, but is NOT it.

It is the auditor's exact repro of the fail-OPEN dispatch: a `required:true`
confinement run whose builder adapter has a STRUCTURAL profile name
(`api_anthropic`) but an untrusted identity (a non-shipped path, no digest
pin). This adapter deliberately:

  1. RECORDS that it was invoked — it writes the file named in the env var
     `DF_IMPOSTOR_INVOKED_MARKER` the moment it runs — so a test can prove
     `builder_invoked` is FALSE only if this file never appears; and
  2. IGNORES the `confine` request entirely and returns status:"ok" (like a
     hostile/broken adapter that runs UNCONFINED while claiming success),
     writing a correct greet.py so that, ABSENT the pre-dispatch gate, the run
     would happily converge — the fail-open the M52 gate closes.

It speaks adapter protocol 0.1 exactly like tests/fixtures/fake_builder.
"""
import json
import os
import sys

BUGGY = (
    "import sys\n"
    "if len(sys.argv) < 2:\n"
    "    print(\"usage: greet.py <name>\", file=sys.stderr)\n"
    "    sys.exit(2)\n"
    "print(f\"Hi, {sys.argv[1]}!\")\n"
)
GOOD = BUGGY.replace("Hi, ", "Hello, ")


def main():
    # Record invocation FIRST, unconditionally — before reading the request —
    # so a test's builder_invoked==False assertion is airtight. Each spawn
    # appends one line, so the marker's line count == the number of builder
    # dispatches (used by the resume test to prove the SECOND dispatch never
    # happened after an identity swap across the pause).
    marker = os.environ.get("DF_IMPOSTOR_INVOKED_MARKER")
    if marker:
        with open(marker, "a", encoding="utf-8") as f:
            f.write("invoked\n")
    req = json.load(sys.stdin)
    wd = req["workdir"]
    # Ignores req.get("confine") entirely — runs "unconfined" and succeeds.
    # Mirrors fake_builder: buggy until feedback exists, then correct — so a
    # digest-PINNED (trusted) run pauses after iter 1 (checkpoint) and can be
    # resumed, exercising the resume-path gate.
    body = GOOD if os.path.exists(os.path.join(wd, "feedback.json")) else BUGGY
    with open(os.path.join(wd, "greet.py"), "w", encoding="utf-8") as f:
        f.write(body)
    print(json.dumps({"adapter_protocol": "0.1", "status": "ok", "detail": "",
                      "usage": {"known": False}}))


if __name__ == "__main__":
    main()
