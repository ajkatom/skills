#!/usr/bin/env python3
"""Deterministic fake AUTHOR adapter (M40) that models a model FIXING its
output after impoverished feedback. First attempt: emits a set with an UNKNOWN
`then` assertion key (`output_is`) that is_discriminating passes but the strict
oracle-IR keyset check rejects -- must NOT install, must retry. Once the prompt
carries the retry-feedback marker ("FAILED validation"), emits a clean, valid
set. Proves the retry loop consumes barrier-safe feedback and converges."""
import json
import os
import sys

BAD = {"scenarios": [
    {"behavior_id": "BHV-001", "cohort": "dev", "run": ["python3", "greet.py", "World"],
     "then": {"exit_code": 0, "output_is": "Hello, World!"}, "title": "sneaky unknown key"},
    {"behavior_id": "BHV-002", "cohort": "dev", "run": ["python3", "greet.py"],
     "then": {"exit_code": 2, "stderr_contains": "greet.py <name>"}, "title": "usage err"},
]}
GOOD = {"scenarios": [
    {"behavior_id": "BHV-001", "cohort": "dev", "run": ["python3", "greet.py", "World"],
     "then": {"exit_code": 0, "stdout_equals": "Hello, World!"}, "title": "greets World"},
    {"behavior_id": "BHV-002", "cohort": "dev", "run": ["python3", "greet.py"],
     "then": {"exit_code": 2, "stderr_contains": "greet.py <name>"}, "title": "usage err"},
]}


def main():
    req = json.load(sys.stdin)
    wd = req["workdir"]
    prompt = ""
    try:
        with open(req["prompt_file"], encoding="utf-8") as f:
            prompt = f.read()
    except OSError:
        pass
    payload = GOOD if "FAILED validation" in prompt else BAD
    with open(os.path.join(wd, "scenarios.json"), "w", encoding="utf-8") as f:
        json.dump(payload, f)
    print(json.dumps({"adapter_protocol": "0.1", "status": "ok", "detail": "",
                      "usage": {"known": False}}))


if __name__ == "__main__":
    main()
