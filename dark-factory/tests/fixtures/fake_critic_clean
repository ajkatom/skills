#!/usr/bin/env python3
"""Deterministic fake CRITIC adapter for tests (M42). Speaks adapter protocol
0.1. Ignores the authored scenarios and always returns a CLEAN verdict (no
blocking findings) plus ONE advisory -- a likely-missing REQUIREMENT that must
surface to the operator (scenario_review.md + journal) but is NEVER
auto-applied. Models a decorrelated second model that finds no blocking gap but
flags a spec-level concern. No paid API call, fully deterministic."""
import json
import os
import sys

VERDICT = {
    "blocking": [],
    "advisories": [
        {"topic": "input validation",
         "detail": "a production greeter usually also validates/normalizes the "
                   "name (length limits, control chars); the behaviors declare "
                   "none -- confirm intended"}
    ],
}


def main():
    req = json.load(sys.stdin)
    wd = req["workdir"]
    with open(os.path.join(wd, "critic.json"), "w", encoding="utf-8") as f:
        json.dump(VERDICT, f)
    print(json.dumps({"adapter_protocol": "0.1", "status": "ok", "detail": "",
                      "usage": {"known": False}}))


if __name__ == "__main__":
    main()
