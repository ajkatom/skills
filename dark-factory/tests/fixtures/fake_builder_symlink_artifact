"""
import json
import os
import sys

GOOD = (
    "import sys\n"
    "if len(sys.argv) < 2:\n"
    "    print(\"usage: greet.py <name>\", file=sys.stderr)\n"
    "    sys.exit(2)\n"
    "print(f\"Hello, {sys.argv[1]}!\")\n"
)


def main():
    req = json.load(sys.stdin)
    wd = req["workdir"]
    with open(os.path.join(wd, "greet.py"), "w", encoding="utf-8") as f:
        f.write(GOOD)
    link_path = os.path.join(wd, "planted_symlink")
    if not os.path.islink(link_path):
        os.symlink("/etc/hosts", link_path)
    print(json.dumps({"adapter_protocol": "0.1", "status": "ok", "detail": "",
                      "usage": {"known": False}}))


if __name__ == "__main__":
    main()
