#!/usr/bin/env python3
"""Deterministic fake builder for the M43a property e2e. Speaks adapter
protocol 0.1.

Behavior: without <workdir>/feedback.json writes a FRAGILE app.py that
raises (interpreter traceback) on any non-alphanumeric argument -- the
robustness bug a fixed example can't catch but a fuzz property does. With
feedback present (which can only say behavior-id + "property_violated",
never the generated input) writes the HARDENED version that rejects bad
input cleanly. Never reads scenarios (cannot -- they are not reachable
from the workspace).
"""
import json
import os
import sys

FRAGILE = (
    "import sys\n"
    "v = sys.argv[1]\n"
    "if not v.isalnum():\n"
    "    raise ValueError('cannot handle %r' % v)\n"
    "print('stored ' + v)\n"
)

HARDENED = (
    "import sys\n"
    "v = sys.argv[1]\n"
    "if not v.isalnum():\n"
    "    print('error: rejected input', file=sys.stderr)\n"
    "    sys.exit(2)\n"
    "print('stored ' + v)\n"
)


def main():
    req = json.load(sys.stdin)
    wd = req["workdir"]
    body = HARDENED if os.path.exists(os.path.join(wd, "feedback.json")) else FRAGILE
    with open(os.path.join(wd, "app.py"), "w", encoding="utf-8") as f:
        f.write(body)
    print(json.dumps({"adapter_protocol": "0.1", "status": "ok", "detail": "",
                      "usage": {"known": False}}))


if __name__ == "__main__":
    main()
