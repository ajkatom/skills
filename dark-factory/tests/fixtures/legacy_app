#!/usr/bin/env python3
"""Tiny deterministic stdlib CLI standing in for a pre-existing ("brownfield")
codebase. Used by df_brownfield characterization tests to capture regression
guards against a real subprocess.

  legacy_app add A B  -> prints int(A)+int(B), exit 0
  anything else       -> stderr message, exit 2
"""
import sys


def main(argv):
    if len(argv) == 3 and argv[0] == "add":
        try:
            a, b = int(argv[1]), int(argv[2])
        except ValueError:
            sys.stderr.write("legacy_app: add requires two integers\n")
            return 2
        print(a + b)
        return 0
    sys.stderr.write("legacy_app: unknown or bad args\n")
    return 2


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
