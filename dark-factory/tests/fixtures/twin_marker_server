#!/usr/bin/env python3
"""A stdlib HTTP twin for M21 Task 2's verify_launch e2e. Binds an ephemeral
port, writes host:port to $DF_ENDPOINT_FILE, then serves GET /value -> a
FIXED marker string given as argv[1] (200). Used by a twin def with two
DIFFERENT instances of this SAME script -- one launched via `launch` (the
build impl, argv[1]=<build marker>) and one via `verify_launch` (the verify
impl, argv[1]=<verify marker>) -- so the served value differs by PHASE, not
by any request input. This is what lets the e2e test prove a builder that
hardcodes the build-phase marker fails at verify: the running process (and
therefore the value GET /value returns) is a genuinely different twin
instance once phase="verify" swaps in verify_launch."""
import os
import sys
from http.server import BaseHTTPRequestHandler, HTTPServer


class H(BaseHTTPRequestHandler):
    def do_GET(self):
        if self.path == "/value":
            body = MARKER.encode()
            self.send_response(200)
            self.send_header("Content-Length", str(len(body)))
            self.end_headers()
            self.wfile.write(body)
        else:
            self.send_response(404); self.end_headers()

    def log_message(self, *a):  # quiet
        pass


def main():
    srv = HTTPServer(("127.0.0.1", 0), H)
    host, port = srv.server_address
    ep = os.environ.get("DF_ENDPOINT_FILE")
    if ep:
        with open(ep, "w", encoding="utf-8") as f:
            f.write(f"{host}:{port}")
    srv.serve_forever()


if __name__ == "__main__":
    MARKER = sys.argv[1] if len(sys.argv) > 1 else "unknown"
    main()
