#!/usr/bin/env python3
"""Codex builder adapter, protocol 0.1. Invokes `codex exec` headless with
cwd = the build workspace. dark-factory provides the OS sandbox itself (the
standard tier wraps this adapter), so Codex's own sandbox is disabled and the
git-repo check is skipped. No -m pin (uses the user's ~/.codex default; pinning
-codex variants breaks ChatGPT-account auth). The model sees only the prompt
file content (spec + ID feedback) and the workspace directory.

When req["confine"] is true, argv is built from df_confine's probe-verified
codex profile instead (mcp_servers disabled — MCP is the escalation path
this profile closes; codex's own sandbox is still disabled in favor of
dark-factory's OS/container sandbox either way)."""
import json
import os
import shutil
import subprocess
import sys

sys.path.insert(0, os.path.dirname(os.path.dirname(os.path.abspath(__file__))))
import df_confine  # noqa: E402  (path must be set up first)


def respond(status, detail=""):
    print(json.dumps({"adapter_protocol": "0.1", "status": status,
                      "detail": detail, "usage": {"known": False}}))


def main():
    try:
        req = json.load(sys.stdin)
        with open(req["prompt_file"], encoding="utf-8") as f:
            prompt = f.read()
    except (json.JSONDecodeError, KeyError, TypeError, OSError) as e:
        respond("error", f"bad adapter request: {e}")
        return
    confine = bool(req.get("confine"))
    if confine and not df_confine.is_supported("codex"):
        respond("error", "confinement unsupported for codex")
        return
    if shutil.which("codex") is None:
        respond("error", "codex CLI not found on PATH")
        return
    if confine:
        argv = df_confine.confinement_flags("codex", prompt)
    else:
        argv = ["codex", "exec", "--sandbox", "danger-full-access",
                "--skip-git-repo-check", prompt]
    try:
        proc = subprocess.run(
            argv,
            cwd=req["workdir"],
            timeout=req.get("timeout_s", 600),
            capture_output=True,
            text=True,
            stdin=subprocess.DEVNULL,
        )
    except subprocess.TimeoutExpired:
        respond("error", "codex CLI timed out")
        return
    if proc.returncode != 0:
        respond("error", (proc.stderr or proc.stdout)[-2000:])
        return
    respond("ok")


if __name__ == "__main__":
    main()
